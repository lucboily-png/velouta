              vivre ton moment privé.
            </p>

            <button
              onClick={() => setShowOfflineModal(false)}
              style={{
                marginTop: 20,
                width: '100%',
                padding: 14,
                borderRadius: 14,
                border: 'none',
                background: '#8b5e83',
                color: 'white',
                fontWeight: 700,
                cursor: 'pointer',
              }}
            >
              Fermer
            </button>
          </div>
        </div>
      )}
    </main>
  )
}