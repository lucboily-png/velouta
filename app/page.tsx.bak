'use client'

import { useEffect, useState } from 'react'

export default function Home() {
  const [isOnline, setIsOnline] = useState(true)
  const [loadingStatus, setLoadingStatus] = useState(true)
  const [showOfflineModal, setShowOfflineModal] = useState(false)

  const loadStatus = async () => {
    try {
      const res = await fetch('/api/admin-status')
      const data = await res.json()
      setIsOnline(data.online)
    } catch {
      setIsOnline(false)
    } finally {
      setLoadingStatus(false)
    }
  }

  useEffect(() => {
    loadStatus()

    fetch('/api/track-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        page: 'landing-chat',
        userAgent: navigator.userAgent,
      }),
    })

    const interval = setInterval(loadStatus, 8000)
    return () => clearInterval(interval)
  }, [])

  const checkout = async (price: string) => {
    await loadStatus()

    if (!isOnline) {
      setShowOfflineModal(true)
      return
    }

    const res = await fetch('/api/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plan: price }),
    })

    const data = await res.json()
    window.location.href = data.url
  }

  return (
    <main
      style={{
        background:
          'radial-gradient(circle at top right, #fff3f8, #fdeff2 45%, #f9edf5 100%)',
        minHeight: '100vh',
        color: '#2f2a2a',
        fontFamily: 'Inter, sans-serif',
      }}
    >

      {/* NAV + LOGO + LIVE STATUS (AMÉLIORÉ) */}
      <div
        style={{
          position: 'absolute',
          top: 20,
          left: 0,
          width: '100%',
          display: 'flex',
          justifyContent: 'center',
          zIndex: 20,
        }}
      >
        <div style={{ width: '1200px', padding: '0 20px', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>

          <img src="/images/logo.png" style={{ height: 110 }} />

          <div
            style={{
              background: isOnline ? 'rgba(46, 204, 113,0.12)' : 'rgba(231, 76, 60,0.12)',
              padding: '10px 16px',
              borderRadius: 999,
              fontSize: 13,
              fontWeight: 600,
              display: 'flex',
              alignItems: 'center',
              gap: 8,
            }}
          >
            <span
              style={{
                width: 8,
                height: 8,
                borderRadius: 999,
                background: isOnline ? '#2ecc71' : '#e74c3c',
              }}
            />
            {loadingStatus
              ? 'Vérification...'
              : isOnline
              ? 'En ligne — réponse immédiate'
              : 'Hors ligne — bientôt de retour'}
          </div>

        </div>
      </div>

      {/* HERO (PLUS PERSUASIF) */}
      <section
        style={{
          maxWidth: 1200,
          margin: '0 auto',
          padding: '130px 20px 80px',
          display: 'grid',
          gridTemplateColumns: '1.1fr 0.9fr',
          gap: 50,
          alignItems: 'center',
        }}
      >

        <div>

          <div
            style={{
              display: 'inline-block',
              background: 'rgba(139,94,131,0.08)',
              color: '#8b5e83',
              padding: '10px 16px',
              borderRadius: 999,
              fontSize: 12,
              fontWeight: 700,
              letterSpacing: '1px',
              marginBottom: 10,
            }}
          >
            ESPACE PRIVÉ • CONFIDENTIEL • SANS JUGEMENT
          </div>

          <h1
            style={{
              fontSize: 64,
              lineHeight: 1.05,
              marginBottom: 18,
              fontFamily: 'Playfair Display, serif',
              fontWeight: 700,
            }}
          >
            Parfois,
            <br />
            tu as juste besoin d’être écoutée
          </h1>

          <p style={{ fontSize: 20, lineHeight: 1.8, color: '#5a4f4f' }}>
            Pas de conseils forcés. Pas de jugement. Pas d’analyse.
            <br />
            Juste une conversation humaine, simple, calme et réelle.
          </p>

          <p style={{ marginTop: 18, fontSize: 16, color: '#7a6a6a' }}>
            Ici, tu peux déposer ce que tu ressens sans devoir l’expliquer parfaitement.
          </p>

          <button
            onClick={() =>
              document.getElementById('pricing')?.scrollIntoView({ behavior: 'smooth' })
            }
            style={{
              marginTop: 32,
              padding: '18px 30px',
              borderRadius: 16,
              border: 'none',
              background:
                'linear-gradient(135deg,#8b5e83,#6f4768,#9a6d92)',
              color: 'white',
              fontWeight: 700,
              fontSize: 16,
              cursor: 'pointer',
              boxShadow: '0 18px 45px rgba(139,94,131,0.28)',
            }}
          >
            Commencer un moment privé ✨
          </button>

        </div>

        {/* IMAGE + STATUS INTÉGRÉ */}
        <div
          style={{
            position: 'relative',
            height: 700,
            borderRadius: 34,
            overflow: 'hidden',
            boxShadow: '0 30px 80px rgba(0,0,0,0.16)',
          }}
        >
          <img src="/images/2.jpg" style={{ width: '100%', height: '100%', objectFit: 'cover' }} />

          <div
            style={{
              position: 'absolute',
              inset: 0,
              background:
                'linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.05))',
            }}
          />

          {/* STATUS PLUS HUMAIN */}
          <div
            style={{
              position: 'absolute',
              left: 24,
              bottom: 24,
              background: 'rgba(255,255,255,0.95)',
              padding: '14px 18px',
              borderRadius: 18,
              fontSize: 14,
              fontWeight: 600,
            }}
          >
            {isOnline ? '🟢 Disponible — réponse rapide' : '🔴 Hors ligne — reviens bientôt'}
          </div>
        </div>
      </section>

      {/* EXPERIENCE (MICRO COPY AMÉLIORÉ) */}
      <section
        style={{
          maxWidth: 1200,
          margin: '0 auto',
          padding: '20px 20px 100px',
        }}
      >

        <div style={{ textAlign: 'center', marginBottom: 50 }}>

          <p style={{ color: '#8b5e83', fontSize: 13, fontWeight: 700 }}>
            UNE EXPÉRIENCE SIMPLE ET HUMAINE
          </p>

          <h2 style={{ fontSize: 44, fontFamily: 'Playfair Display, serif' }}>
            Un moment qui t’appartient vraiment
          </h2>

          <p style={{ fontSize: 19, color: '#5a4f4f', marginTop: 18 }}>
            Tu peux parler librement. Ralentir. Respirer. Ou simplement être là.
            <br />
            Tout se fait à ton rythme, sans aucune pression.
          </p>

        </div>

      </section>

      {/* OFFRE (UNCHANGED BUT CLEAN) */}
      <section id="pricing" style={{ maxWidth: 1200, margin: '0 auto', padding: '40px 20px 120px' }}>

        <div style={{ textAlign: 'center', marginBottom: 60 }}>
          <h2 style={{ fontSize: 52, fontFamily: 'Playfair Display, serif' }}>
            Choisis ton moment
          </h2>

          <p style={{ color: '#6d5d5d', marginTop: 10 }}>
            Tu peux commencer doucement ou prendre plus de temps.
          </p>
        </div>

        {/* CARDS (KEEP YOUR ORIGINAL STYLE) */}
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 30 }}>
          {[
            { t: '25 min', p: '29$', d: 'Un moment simple pour respirer', plan: '25' },
            { t: '45 min', p: '49$', d: 'Le choix le plus naturel', plan: '45', featured: true },
            { t: '60 min', p: '69$', d: 'Un moment plus profond', plan: '60' },
          ].map((p) => (
            <div key={p.plan} style={{ padding: 40, borderRadius: 30, background: p.featured ? '#8b5e83' : 'rgba(255,255,255,0.7)', color: p.featured ? 'white' : '#2f2a2a' }}>

              <h3 style={{ fontSize: 28 }}>{p.t}</h3>
              <p style={{ opacity: 0.8 }}>{p.d}</p>

              <div style={{ fontSize: 48, fontWeight: 700 }}>{p.p}</div>

              <button
                onClick={() => checkout(p.plan)}
                style={{
                  marginTop: 20,
                  width: '100%',
                  padding: 14,
                  borderRadius: 14,
                  border: 'none',
                  background: p.featured ? 'white' : '#8b5e83',
                  color: p.featured ? '#8b5e83' : 'white',
                  fontWeight: 700,
                }}
              >
                Commencer
              </button>

            </div>
          ))}
        </div>

      </section>

      {/* OFFLINE MODAL (KEEP BUT CLEAN) */}
      {showOfflineModal && (
        <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.6)', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>

          <div style={{ background: 'white', padding: 30, borderRadius: 20, maxWidth: 400, textAlign: 'center' }}>

            <h3>Je suis hors ligne</h3>

            <p style={{ color: '#666' }}>
              Tu peux revenir bientôt ou choisir un autre moment.
            </p>

            <button
              onClick={() => setShowOfflineModal(false)}
              style={{ marginTop: 20, padding: 12, background: '#8b5e83', color: 'white', borderRadius: 12, width: '100%' }}
            >
              Fermer
            </button>

          </div>

        </div>
      )}

    </main>
  )
}