@import "tailwindcss";

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
  background: #0f0b11;
  color: white;
  font-family: Inter, sans-serif;
}

img {
  display: block;
  max-width: 100%;
}

button {
  cursor: pointer;
  border: none;
}

::selection {
  background: rgba(255,255,255,0.2);
}

::-webkit-scrollbar {
  width: 10px